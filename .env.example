# Copy to .env for local development. Do NOT commit the real .env (it is gitignored).
# These values are consumed by docker-compose.yml.

POSTGRES_USER=connectoee
POSTGRES_PASSWORD=connectoee_dev_pw
POSTGRES_DB=connectoee
# Host port for the dev DB. 5433 avoids clashing with a local/other Postgres on 5432.
POSTGRES_PORT=5433
